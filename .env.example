# Root .env — used by docker-compose.release.yml on the production server.
# Copy to .env and fill in real values.

# PostgreSQL
POSTGRES_USER=trendbuy
POSTGRES_PASSWORD=changeme
POSTGRES_DB=trendastana

# Telegram bot (contact form)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Admin API key — protects create/update/delete endpoints.
# Generate with: openssl rand -hex 32
ADMIN_API_KEY=
